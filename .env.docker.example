# Copy this file to .env.docker before running Docker Compose.
# For build-time values such as NEXT_PUBLIC_EAZO_APP_ID, pass it with:
# docker compose --env-file .env.docker build

# Compose-only settings.
DOCKER_WEB_PORT=3000
# Bound to 127.0.0.1 by docker-compose.yml so the database is not public.
DOCKER_POSTGRES_PORT=5432
DOCKER_DATABASE_URL=postgresql://worldcup:worldcup@postgres:5432/worldcup
DOCKER_DATABASE_SSL=disable
DOCKER_DATABASE_PREPARE=false
DOCKER_DATABASE_POOL_MAX=5
POSTGRES_USER=worldcup
POSTGRES_PASSWORD=worldcup
POSTGRES_DB=worldcup

# Required for production/admin features.
CRON_SECRET=replace_with_a_long_random_string
ADMIN_PASSWORD=replace_with_a_strong_admin_password
ADMIN_SESSION_SECRET=replace_with_a_long_random_session_secret

# Eazo server credentials.
EAZO_PRIVATE_KEY=your_eazo_private_key_here
EAZO_APP_ID=your_eazo_app_id_here
NEXT_PUBLIC_EAZO_APP_ID=your_eazo_app_id_here
EAZO_PLATFORM_API_BASE=https://eazo.ai

# Data source API keys.
DATA_SOURCE_WORLDCUPAPI_COM_API_KEY=
DATA_SOURCE_API_FOOTBALL_WORLDCUP_FIXTURES_API_KEY=
DATA_SOURCE_API_FOOTBALL_WORLDCUP_DETAILS_API_KEY=
DATA_SOURCE_API_FOOTBALL_WORLDCUP_TEAMS_API_KEY=
DATA_SOURCE_FOOTBALL_DATA_ORG_API_KEY=
DATA_SOURCE_FOOTBALL_DATA_ORG_TEAMS_API_KEY=
DATA_SOURCE_THE_ODDS_API_WORLDCUP_API_KEY=
DATA_SOURCE_ODDS_API_IO_WORLDCUP_API_KEY=
DATA_SOURCE_THESPORTSDB_WORLDCUP_API_KEY=
DATA_SOURCE_THESPORTSDB_WORLDCUP_TEAMS_API_KEY=
DATA_SOURCE_ZAFRONIX_WORLDCUP_API_KEY=
DATA_SOURCE_BALLDONTLIE_FIFA_API_KEY=
DATA_SOURCE_CURRENTS_WORLDCUP_NEWS_API_KEY=
DATA_SOURCE_NEWSAPI_WORLDCUP_API_KEY=

# AI provider API keys.
AI_PROVIDER_OPENAI_API_KEY=
AI_PROVIDER_GEMINI_API_KEY=
AI_PROVIDER_DEEPSEEK_API_KEY=
AI_PROVIDER_XIAOMI_MIMO_API_KEY=
AI_PROVIDER_KIMI_CODING_API_KEY=
AI_PROVIDER_BIGMODEL_API_KEY=

# Optional translation endpoints.
FREE_TRANSLATE_ENDPOINT=
FREE_TRANSLATE_ENDPOINTS=

# Worker tuning.
WORKER_ID=
WORKER_IDLE_MS=5000
WORKER_BUSY_MS=250
WORKER_SCHEDULER_DISABLED=0
WORKER_SCHEDULER_INTERVAL_MS=30000
WORKER_MATCH_WINDOW_REFRESH_MS=
WORKER_TOURNAMENT_MATCH_REFRESH_MS=
WORKER_QUIET_MATCH_REFRESH_MS=
WORKER_MATCH_WINDOW_NEWS_REFRESH_MS=
WORKER_TOURNAMENT_NEWS_REFRESH_MS=
WORKER_QUIET_NEWS_REFRESH_MS=
WORKER_MATCH_WINDOW_MARKET_REFRESH_MS=
WORKER_TOURNAMENT_MARKET_REFRESH_MS=
WORKER_QUIET_MARKET_REFRESH_MS=
WORKER_MATCH_WINDOW_ODDS_REFRESH_MS=
WORKER_TOURNAMENT_ODDS_REFRESH_MS=
WORKER_QUIET_ODDS_REFRESH_MS=
WORKER_TEAMS_REFRESH_MS=
WORKER_TEAM_ROASTS_REFRESH_MS=
WORKER_PLAYER_ROASTS_REFRESH_MS=
