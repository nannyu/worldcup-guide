{
  "name": "worldcup-guide",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.9",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "cleanup:demo": "bun scripts/cleanup-demo.ts",
    "data:refresh": "bun scripts/refresh-data.ts",
    "data:init": "bun scripts/refresh-data.ts --init",
    "worker": "bun scripts/background-worker.ts",
    "tools:audit": "node scripts/audit-tools.mjs",
    "sdk:sync": "rm -rf node_modules/@eazo/sdk && mkdir -p node_modules/@eazo/sdk && cp ../eazo-sdk/sdk/package.json node_modules/@eazo/sdk/ && cp -r ../eazo-sdk/sdk/dist node_modules/@eazo/sdk/dist && cp -R ../eazo-sdk/sdk/node_modules node_modules/@eazo/sdk/node_modules",
    "sdk:dev": "(cd ../eazo-sdk/sdk && npm run build) && bun run sdk:sync",
    "sdk:watch": "bun run scripts/sdk-watch.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun src/lib/db/migrate.ts",
    "db:seed:fifa": "bun src/lib/db/seed-fifa-schedule.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:drop": "drizzle-kit drop"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.0",
    "@eazo/sdk": "0.22.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "elliptic": "file:vendor/elliptic",
    "framer-motion": "^12.38.0",
    "i18next": "^25.8.14",
    "lucide-react": "^1.8.0",
    "next": "^16.2.10",
    "next-themes": "^0.4.6",
    "postgres": "^3.4.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-i18next": "^16.5.6",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.10",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "brace-expansion": "file:vendor/brace-expansion",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "^16.2.10",
    "shadcn": "^4.13.0",
    "tailwindcss": "^4",
    "tsx": "^4.23.0",
    "typescript": "^5"
  },
  "overrides": {
    "@babel/core": "7.29.7",
    "axios": "0.32.0",
    "brace-expansion": "file:vendor/brace-expansion",
    "elliptic": "file:vendor/elliptic",
    "esbuild": "0.28.1",
    "fast-uri": "4.1.0",
    "form-data": "4.0.6",
    "hono": "4.12.27",
    "ip-address": "10.2.0",
    "js-yaml": "5.2.1",
    "postcss": "8.5.16",
    "qs": "6.15.3",
    "sm-crypto": "0.4.0"
  }
}
