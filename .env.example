# Eazo Private Key to decrypt the user session token on the server
EAZO_PRIVATE_KEY=your_eazo_private_key_here

# Eazo app ID. Read by RootLayout and passed into <EazoProvider> as a prop.
EAZO_APP_ID=your_eazo_app_id_here

# PostgreSQL connection string (used by Drizzle ORM)
# Runtime should use the Supabase pooler URL in Vercel/Railway.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:password@localhost:5432/myapp
# Migrations can use the Supabase direct connection URL.
DATABASE_DIRECT_URL=
# Supabase production usually needs SSL. Use "disable" for local Postgres only.
DATABASE_SSL=require
# Supabase transaction pooler should keep prepared statements disabled.
DATABASE_PREPARE=false
DATABASE_POOL_MAX=5

# Shared secret Vercel Cron uses to authenticate scheduled invocations of
# `/api/notifications/cron/daily-digest`. Generate any high-entropy string
# (e.g. `openssl rand -hex 32`) and set it both here and in Vercel's project
# env. Vercel automatically injects `Authorization: Bearer ${CRON_SECRET}`
# when firing crons declared in `vercel.json`.
CRON_SECRET=replace_with_a_long_random_string

# Admin console
# In local development, the app falls back to ADMIN_PASSWORD=admin123 when unset.
# In production, both variables are required.
ADMIN_PASSWORD=replace_with_a_strong_admin_password
ADMIN_SESSION_SECRET=replace_with_a_long_random_session_secret

# Data source API keys
# Runtime config stores only these env var names; actual secrets stay in .env.
DATA_SOURCE_WORLDCUPAPI_COM_API_KEY=
DATA_SOURCE_API_FOOTBALL_WORLDCUP_FIXTURES_API_KEY=
DATA_SOURCE_API_FOOTBALL_WORLDCUP_DETAILS_API_KEY=
DATA_SOURCE_API_FOOTBALL_WORLDCUP_TEAMS_API_KEY=
DATA_SOURCE_FOOTBALL_DATA_ORG_API_KEY=
DATA_SOURCE_FOOTBALL_DATA_ORG_TEAMS_API_KEY=
DATA_SOURCE_THE_ODDS_API_WORLDCUP_API_KEY=
DATA_SOURCE_ODDS_API_IO_WORLDCUP_API_KEY=
DATA_SOURCE_THESPORTSDB_WORLDCUP_API_KEY=
DATA_SOURCE_THESPORTSDB_WORLDCUP_TEAMS_API_KEY=
DATA_SOURCE_ZAFRONIX_WORLDCUP_API_KEY=
DATA_SOURCE_BALLDONTLIE_FIFA_API_KEY=
DATA_SOURCE_CURRENTS_WORLDCUP_NEWS_API_KEY=
DATA_SOURCE_NEWSAPI_WORLDCUP_API_KEY=

# AI provider API keys
AI_PROVIDER_OPENAI_API_KEY=
AI_PROVIDER_GEMINI_API_KEY=
AI_PROVIDER_DEEPSEEK_API_KEY=
AI_PROVIDER_XIAOMI_MIMO_API_KEY=
AI_PROVIDER_KIMI_CODING_API_KEY=
AI_PROVIDER_BIGMODEL_API_KEY=

# Optional free translation endpoints for article title/body translation.
# Defaults to Google Translate free endpoint, then Edge public endpoint, MyMemory, and LibreTranslate-compatible endpoints.
# FREE_TRANSLATE_ENDPOINT is kept for one custom Google-compatible endpoint.
# FREE_TRANSLATE_ENDPOINTS accepts comma-separated Google-compatible endpoints.
FREE_TRANSLATE_ENDPOINT=
FREE_TRANSLATE_ENDPOINTS=

# Railway background worker
WORKER_ID=
WORKER_IDLE_MS=5000
WORKER_BUSY_MS=250
WORKER_SCHEDULER_DISABLED=0
WORKER_SCHEDULER_INTERVAL_MS=30000

# Optional worker refresh cadence overrides, in milliseconds.
# Defaults are dynamic: matches 60s in match windows, 15m in tournament mode, 60m off-season.
# News defaults to 15m/30m/60m; market radar 10m/30m/6h; odds 60m/2h/6h.
WORKER_MATCH_WINDOW_REFRESH_MS=
WORKER_TOURNAMENT_MATCH_REFRESH_MS=
WORKER_QUIET_MATCH_REFRESH_MS=
WORKER_MATCH_WINDOW_NEWS_REFRESH_MS=
WORKER_TOURNAMENT_NEWS_REFRESH_MS=
WORKER_QUIET_NEWS_REFRESH_MS=
WORKER_MATCH_WINDOW_MARKET_REFRESH_MS=
WORKER_TOURNAMENT_MARKET_REFRESH_MS=
WORKER_QUIET_MARKET_REFRESH_MS=
WORKER_MATCH_WINDOW_ODDS_REFRESH_MS=
WORKER_TOURNAMENT_ODDS_REFRESH_MS=
WORKER_QUIET_ODDS_REFRESH_MS=
WORKER_TEAMS_REFRESH_MS=
WORKER_TEAM_ROASTS_REFRESH_MS=
WORKER_PLAYER_ROASTS_REFRESH_MS=
